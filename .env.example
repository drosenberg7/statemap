# Copy to .env and fill in. Load with:  set -a; source .env; set +a
# (or use direnv / your process manager's env support).

# --- ntfy push (required for push alerts) ---------------------------------
# Pick a long, hard-to-guess topic name — anyone who knows it can read your
# alerts. Then subscribe to the SAME topic in the ntfy app on your phone.
NTFY_TOPIC=usopen-tickets-CHANGE-ME-8f3a
NTFY_SERVER=https://ntfy.sh

# --- Optional: official APIs (more reliable than scraping) ----------------
# Free key from https://developer.ticketmaster.com
# TICKETMASTER_API_KEY=
# Free client id from https://seatgeek.com/account/develop
# SEATGEEK_CLIENT_ID=

# --- Optional: pin marketplace event ids for reliable scraping ------------
# TICKPICK_EVENT_IDS=123456,123457
# VIVIDSEATS_PRODUCTION_IDS=987654

# --- Optional: extra notification channels --------------------------------
# Email (SMTP), e.g. a Gmail App Password:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=you@gmail.com
# EMAIL_TO=you@gmail.com
# Discord/Slack incoming webhook:
# WEBHOOK_URL=
